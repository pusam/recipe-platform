# Gemini AI - https://aistudio.google.com/app/apikey 에서 발급
# .env 파일은 절대 커밋하지 마세요. 유출된 키는 즉시 재발급하세요.
GEMINI_API_KEY=your-gemini-api-key-here

# JWT 시크릿 (32바이트 이상, 무작위 값 권장)
# 생성 예시: openssl rand -base64 48
# 운영(prod) 프로파일에서는 반드시 설정해야 하며, 미설정 시 앱이 기동되지 않습니다.
JWT_SECRET=replace-with-random-base64-at-least-32-bytes

# 토큰 만료 시간 (ms). 7일 = 604800000
JWT_EXPIRATION_MS=604800000

# CORS 허용 Origin (쉼표로 구분). 프론트가 별도 호스트로 배포될 때 설정
# APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# H2 콘솔 (dev 전용). 운영에서는 반드시 false
H2_CONSOLE_ENABLED=false

# DB (기본 H2). MariaDB 사용 시 주석 해제
# DB_URL=jdbc:mariadb://localhost:3306/recipe
# DB_USERNAME=recipe
# DB_PASSWORD=
# DB_DRIVER=org.mariadb.jdbc.Driver
